{
  "item": [
    {
      "id": "e0a4caef-dd1e-428a-8b55-8bc573721177",
      "name": "Speech to Speech",
      "description": {
        "content": "Endpoints for converting speech from one voice to another while preserving the original speech characteristics.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "d609ad33-6e0a-4e03-a1c8-549a41e18be1",
          "name": "Voice changer",
          "request": {
            "name": "Voice changer",
            "description": {
              "content": "Converts an audio recording to use a different voice while preserving the original speech content, timing, and emotional delivery. The target voice can be any voice available in the user's library.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "speech-to-speech",
                ":voice_id"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "output_format",
                  "value": "mp3_44100_128",
                  "description": "The desired output audio format."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "voice_id",
                  "description": "(Required) The identifier of the target voice to convert the audio to."
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              },
              {
                "key": "Accept",
                "value": "audio/mpeg"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "audio",
                  "type": "file",
                  "description": "(Required) The source audio file containing the speech to convert. Supports common audio formats including MP3, WAV, and OGG."
                },
                {
                  "key": "model_id",
                  "value": "<string>",
                  "type": "text",
                  "description": "The identifier of the model to use for voice conversion."
                },
                {
                  "key": "voice_settings",
                  "value": "{\"stability\":\"<number>\",\"similarity_boost\":\"<number>\",\"style\":\"<number>\",\"use_speaker_boost\":\"<boolean>\"}",
                  "type": "text",
                  "description": "Voice settings to override the default settings for the target voice."
                },
                {
                  "key": "seed",
                  "value": "<integer>",
                  "type": "text",
                  "description": "A seed value for deterministic generation."
                }
              ]
            }
          },
          "response": [
            {
              "id": "ab95e0bf-c502-4939-8d71-04a2e869809c",
              "name": "Voice conversion completed successfully",
              "originalRequest": {
