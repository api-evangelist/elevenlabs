  "item": [
    {
      "id": "09e38256-a589-4e1f-853b-813f30b502e5",
      "name": "Speech to Text",
      "description": {
        "content": "Endpoints for converting audio into text transcriptions with support for multiple languages and audio formats.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "0b10b284-3784-4121-a748-d8a2c4b6e2a2",
          "name": "Convert speech to text",
          "request": {
            "name": "Convert speech to text",
            "description": {
              "content": "Transcribes an audio file into text. Supports multiple audio formats and languages. Returns the transcribed text along with optional word-level timing information.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "speech-to-text"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "description": "(Required) The audio file to transcribe. Supports formats including MP3, WAV, FLAC, OGG, and M4A."
                },
                {
                  "key": "model_id",
                  "value": "<string>",
                  "type": "text",
                  "description": "The identifier of the speech-to-text model to use for transcription."
                },
                {
                  "key": "language_code",
                  "value": "<string>",
                  "type": "text",
                  "description": "Language code in ISO 639-1 format to hint the expected language of the audio content."
                },
                {
                  "key": "tag_audio_events",
                  "value": "false",
                  "type": "text",
                  "description": "Whether to tag non-speech audio events such as music, laughter, or applause in the transcription output."
                },
                {
                  "key": "timestamps_granularity",
                  "value": "<string>",
                  "type": "text",
                  "description": "The level of timestamp granularity to include in the response. (This can only be one of none,word,character)"
                }
              ]
            }
          },
          "response": [
            {
              "id": "1ce36968-d001-4636-a038-1f39610341ad",
              "name": "Transcription completed successfully",
