    "_postman_id": "efc5d9f1-61cc-49e6-9b51-9993ed7391bc",
    "name": "ElevenLabs Sound Effects API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The ElevenLabs Sound Effects API generates cinematic sound effects from text descriptions. Developers can describe the desired sound in natural language and receive high-quality audio output. The API supports audio tags for controlling delivery, emotion, emphasis, pauses, and specific sound effects, making it suitable for game development, film production, and multimedia content creation.\n\nContact Support:\n Name: ElevenLabs Support",
      "type": "text/plain"
    }
  }
