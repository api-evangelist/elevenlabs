    "_postman_id": "359c81c6-a460-4d03-a32b-dda8c2bcd4e9",
    "name": "ElevenLabs Music Generation API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The ElevenLabs Music Generation API creates music from text prompts, allowing developers to generate original musical compositions programmatically. Users describe the desired genre, mood, tempo, and instrumentation in natural language and receive generated audio output. The API supports generating stems, lyrics, and full compositions with seamless looping and professional-grade quality.\n\nContact Support:\n Name: ElevenLabs Support",
