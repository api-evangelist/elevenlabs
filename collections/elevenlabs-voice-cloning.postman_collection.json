              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "<string>",
                  "type": "text",
                  "description": "(Required) The name for the cloned voice."
                },
                {
                  "key": "files",
                  "value": "[\"<binary>\",\"<binary>\"]",
                  "type": "text",
                  "description": "(Required) Audio sample files for cloning. A minimum of 60 seconds of clean audio is recommended for best results."
                },
                {
                  "key": "description",
                  "value": "<string>",
                  "type": "text",
                  "description": "Description of the cloned voice and its intended use."
                },
