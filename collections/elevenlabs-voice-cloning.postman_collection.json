    {
      "id": "16876ca1-e522-4753-ae63-f32c3664d6e3",
      "name": "Professional Voice Cloning",
      "description": {
        "content": "Endpoints for creating high-fidelity voice clones from longer audio recordings with professional-grade processing.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "d0afca3e-1807-406d-9649-fa49c6959db7",
          "name": "Create professional voice clone",
          "request": {
            "name": "Create professional voice clone",
            "description": {
              "content": "Initiates professional voice cloning from uploaded audio samples. Requires a minimum of 30 minutes of high-quality recordings. The cloning process takes longer than instant cloning but produces higher fidelity results.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "voices",
                ":voice_id",
                "professional"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "voice_id",
                  "description": "(Required) The identifier of the voice to apply professional cloning to."
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "value": "[\"<binary>\",\"<binary>\"]",
                  "type": "text",
                  "description": "(Required) High-quality audio recordings for professional voice cloning. A minimum of 30 minutes of recordings is required."
                },
                {
                  "key": "consent",
                  "type": "file",
                  "description": "A signed consent form or audio consent from the voice owner authorizing the creation of the voice clone."
                }
              ]
