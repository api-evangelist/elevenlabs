          "id": "945c3187-0880-4d0c-9ffa-f0955d2360c8",
          "name": "Create instant voice clone",
          "request": {
            "name": "Create instant voice clone",
            "description": {
              "content": "Creates a new voice clone from uploaded audio samples using instant voice cloning. Requires a minimum of 60 seconds of clean audio. The cloned voice is immediately available for use with speech generation endpoints.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "voices",
                "add"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
